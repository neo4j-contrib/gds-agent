{
  "mcpServers": {
    "neo4j-gds": {
      "command": "/opt/homebrew/bin/uvx",
      "args": ["gds-agent"],
      "env": {
        "NEO4J_URI": "neo4j://localhost:7687",
        "NEO4J_USERNAME": "neo4j",
        "NEO4J_PASSWORD": "<your-password>",
        "NEO4J_DATABASE": "neo4j",
        "AURA_API_CLIENT_ID": "<optional: enables Aura Graph Analytics session mode>",
        "AURA_API_CLIENT_SECRET": "<optional>",
        "AURA_API_PROJECT_ID": "<optional>"
      }
    }
  }
}
